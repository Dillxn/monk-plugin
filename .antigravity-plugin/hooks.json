{
  "ensure-monk-agent": {
    "PreInvocation": [
      {
        "type": "command",
        "command": "./hooks/ensure-monk-agent.sh",
        "timeout": 10
      }
    ]
  },
  "block-monk": {
    "PreToolUse": [
      {
        "matcher": "run_command",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/block-monk.sh",
            "timeout": 5
          }
        ]
      }
    ]
  },
  "monk-diagnostics": {
    "PostToolUse": [
      {
        "matcher": "write_to_file|replace_file_content|multi_replace_file_content",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/monk-diagnostics.sh",
            "timeout": 30
          }
        ]
      }
    ]
  }
}
